rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidLeaderboardEntry() {
      return hasRequiredFields(['userId', 'displayName', 'score', 'timestamp']) &&
             request.resource.data.userId is string &&
             request.resource.data.displayName is string &&
             request.resource.data.displayName.size() <= 50 &&
             request.resource.data.score is number &&
             request.resource.data.score >= 0 &&
             request.resource.data.timestamp is timestamp;
    }

    match /{collection}/{userId} {
      // Anyone can read the leaderboard
      allow read: if collection in ['leaderboard', 'leaderboard_google', 'leaderboard_facebook', 'leaderboard_playgames', 'leaderboard_guest'];
      
      // Users can only create their own scores
      allow create: if collection in ['leaderboard_google', 'leaderboard_facebook', 'leaderboard_playgames', 'leaderboard_guest'] &&
                    isAuthenticated() && 
                    userId == request.auth.uid &&
                    request.resource.data.userId == request.auth.uid &&
                    isValidLeaderboardEntry();
                    
      // Users can update their own score if it's higher, or just update their display name
      allow update: if collection in ['leaderboard_google', 'leaderboard_facebook', 'leaderboard_playgames', 'leaderboard_guest'] &&
                    isAuthenticated() && 
                    userId == request.auth.uid &&
                    request.resource.data.userId == request.auth.uid &&
                    isValidLeaderboardEntry() &&
                    request.resource.data.score >= resource.data.score;
      
      allow delete: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    hasRequiredFields(['userId', 'displayName', 'text', 'timestamp']) &&
                    request.resource.data.userId is string &&
                    request.resource.data.displayName is string &&
                    request.resource.data.text is string &&
                    request.resource.data.text.size() > 0 &&
                    request.resource.data.text.size() <= 2000 &&
                    request.resource.data.timestamp is timestamp;
      allow read, update, delete: if false;
    }
  }
}
